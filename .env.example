# Canonical URL for this marketing site (Open Graph, footer). Use a hostname that resolves in DNS.
NEXT_PUBLIC_SITE_URL=https://zrolab.com

# Voice gateway (WebSocket + /embed static). Local dev:
NEXT_PUBLIC_ZRO_GATEWAY_URL=http://127.0.0.1:8790

# Optional: when the embed script is served from a different host than the gateway:
# NEXT_PUBLIC_ZRO_EMBED_SNIPPET_ORIGIN=https://voice.example.com
